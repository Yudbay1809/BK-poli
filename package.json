{
  "name": "bk-poli-modern",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "devDependencies": {
    "next": "16.1.6"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "vercel-build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "db:generate": "pnpm --dir db db:generate",
    "db:migrate": "pnpm --dir db db:migrate",
    "db:migrate:deploy": "pnpm --dir db prisma migrate deploy",
    "db:seed": "pnpm --dir db db:seed",
    "db:push": "pnpm --dir db prisma db push",
    "db:studio": "pnpm --dir db prisma studio"
  },
  "workspaces": [
    "apps/*",
    "db"
  ]
}
